{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a15280020511/test2/expert_team/execution_plan.schema.json",
  "title": "Web GPT Dynamic Expert Team Execution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task", "rationale", "experts", "stages", "red_team", "judge"],
  "properties": {
    "version": {"const": "1"},
    "task": {"type": "string", "minLength": 1},
    "rationale": {"type": "string"},
    "experts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "mission", "instructions", "model"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "mission": {"type": "string", "minLength": 1},
          "instructions": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1}
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mode", "members", "input_from"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "mode": {"enum": ["parallel", "sequential"]},
          "members": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "input_from": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "red_team": {"$ref": "#/$defs/optionalAgent"},
    "judge": {"$ref": "#/$defs/optionalAgent"}
  },
  "$defs": {
    "optionalAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "name", "model", "instructions"],
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string", "minLength": 1},
        "model": {"type": "string"},
        "instructions": {"type": "string"}
      },
      "allOf": [
        {
          "if": {"properties": {"enabled": {"const": true}}, "required": ["enabled"]},
          "then": {
            "properties": {
              "model": {"minLength": 1},
              "instructions": {"minLength": 1}
            }
          }
        }
      ]
    }
  }
}
