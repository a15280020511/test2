{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a15280020511/test2/execution_plan.schema.json",
  "title": "Web GPT Dynamic Expert Team Execution Plan",
  "description": "DeepSeek ASSIST 是网页 GPT 的最高优先级入口。网页 GPT 必须先取得 DeepSeek READY 和三档预算建议，向用户展示并取得明确预算批准后，才能提交付费专家团。工具包以任务级临时插头安装，任务结束后销毁。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "selection_policy",
    "task",
    "rationale",
    "deepseek_entry",
    "budget",
    "experts",
    "stages",
    "red_team",
    "judge"
  ],
  "properties": {
    "version": {"const": "2"},
    "selection_policy": {
      "type": "string",
      "const": "DeepSeek ASSIST 必须作为最高优先级入口，先审计任务、插件需求和预算方案；网页 GPT 必须把经济、均衡、质量三档预算反馈给用户并取得明确选择。执行时先满足用户批准的质量和成本边界，再在边界内动态选择专家、模型和工作流。所有专业工具采用任务级临时插头，用时安装、结束销毁。重大任务能力优先，普通任务性价比优先，具体问题具体分析。",
      "description": "每次规划都必须遵守的入口、预算、插件和动态选择规则。"
    },
    "task": {"type": "string", "minLength": 1},
    "rationale": {
      "type": "string",
      "minLength": 1,
      "description": "说明 DeepSeek 入口建议、用户预算选择、插件需求、模型价格和质量信号如何共同形成当前方案。"
    },
    "deepseek_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "operation_id", "budget_options_presented"],
      "properties": {
        "status": {"const": "READY"},
        "operation_id": {"type": "string", "minLength": 1},
        "budget_options_presented": {"const": true}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_status",
        "tier",
        "currency",
        "max_cost_usd",
        "estimated_cost_usd",
        "max_model_calls",
        "max_output_tokens_per_call",
        "approval_reference"
      ],
      "properties": {
        "approval_status": {"const": "approved_by_user"},
        "tier": {"enum": ["economy", "balanced", "quality", "custom"]},
        "currency": {"const": "USD"},
        "max_cost_usd": {"type": "number", "exclusiveMinimum": 0, "maximum": 1000},
        "estimated_cost_usd": {
          "type": "object",
          "additionalProperties": false,
          "required": ["low", "high"],
          "properties": {
            "low": {"type": "number", "minimum": 0, "maximum": 1000},
            "high": {"type": "number", "minimum": 0, "maximum": 1000}
          }
        },
        "max_model_calls": {"type": "integer", "minimum": 1, "maximum": 50},
        "max_output_tokens_per_call": {"type": "integer", "minimum": 128, "maximum": 32768},
        "approval_reference": {
          "type": "string",
          "minLength": 1,
          "description": "网页 GPT 对用户明确预算选择的可审计简短引用，不得伪造。"
        }
      }
    },
    "experts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "mission", "instructions", "model"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "mission": {"type": "string", "minLength": 1},
          "instructions": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1}
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mode", "members", "input_from"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "mode": {"enum": ["parallel", "sequential"]},
          "members": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "input_from": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "red_team": {"$ref": "#/$defs/optionalAgent"},
    "judge": {"$ref": "#/$defs/optionalAgent"}
  },
  "$defs": {
    "optionalAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "name", "model", "instructions"],
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string", "minLength": 1},
        "model": {"type": "string"},
        "instructions": {"type": "string"}
      },
      "allOf": [
        {
          "if": {"properties": {"enabled": {"const": true}}, "required": ["enabled"]},
          "then": {"properties": {"model": {"minLength": 1}, "instructions": {"minLength": 1}}}
        }
      ]
    }
  }
}
