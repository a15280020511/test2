{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a15280020511/test2/execution_plan.schema.json",
  "title": "Web GPT Dynamic Expert Team Execution Plan",
  "description": "Web GPT 是任务规划者。必须先读取 OpenRouter 当前模型情报，再依据 selection_policy 针对具体任务动态选择专家、模型和组合方式。所有付费执行必须通过硬预算预检和角色级 token 上限。若发现技术故障，应交给 DeepSeek Steward REPAIR。",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "selection_policy", "task", "rationale", "experts", "stages", "red_team", "judge"],
  "properties": {
    "version": {"const": "1"},
    "selection_policy": {
      "type": "string",
      "const": "默认采用质量约束下的动态最优组合：先保证任务所需质量，再在满足质量的候选模型中优化成本和速度；随着任务复杂度、风险、价值和不确定性提高，自动增加专家数量、模型多样性和红队强度；重大任务以能力优先，普通任务以性价比优先。不得固定专家数量、固定模型或固定工作流，必须具体问题具体分析。",
      "description": "Web GPT 每次规划和填写 Execution Plan 时必须遵守的固定底层规则。"
    },
    "task": {"type": "string", "minLength": 1},
    "rationale": {
      "type": "string",
      "minLength": 1,
      "description": "说明本次如何依据 selection_policy，结合任务难度、风险、OpenRouter 当前能力、价格、延迟和上下文，决定专家数量、模型、token 和工作流。"
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_total_usd": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 10,
          "default": 1.0,
          "description": "一个逻辑任务包含一次正常执行与最多一次受控恢复的总美元硬上限。"
        },
        "recovery_reserve_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.5,
          "default": 0.3,
          "description": "为一次 DeepSeek 技术恢复预留的比例。正常执行预算为 max_total_usd × (1-reserve)。"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "original_plan_source": {"type": "string"},
        "effective_plan_source": {"type": "string"},
        "original_plan_sha256": {"type": "string"},
        "supervisor_operation_id": {"type": "string"},
        "override_reason": {"type": "string"}
      }
    },
    "experts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {"$ref": "#/$defs/agent"}
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mode", "members", "input_from"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "mode": {"enum": ["parallel", "sequential"]},
          "members": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "input_from": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "failure_policy": {
            "enum": ["fail_fast", "continue_with_partial"],
            "default": "fail_fast"
          },
          "minimum_successful_members": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "red_team": {"$ref": "#/$defs/optionalAgent"},
    "judge": {"$ref": "#/$defs/optionalAgent"}
  },
  "$defs": {
    "agentExecution": {
      "type": "object",
      "properties": {
        "max_completion_tokens": {
          "type": "integer",
          "minimum": 64,
          "maximum": 16384
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 900,
          "default": 240
        },
        "fallback_models": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "agent": {
      "allOf": [
        {"$ref": "#/$defs/agentExecution"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "mission", "instructions", "model"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "mission": {"type": "string", "minLength": 1},
            "instructions": {"type": "string", "minLength": 1},
            "model": {"type": "string", "minLength": 1},
            "max_completion_tokens": {"type": "integer", "minimum": 64, "maximum": 16384, "default": 2200},
            "timeout_seconds": {"type": "integer", "minimum": 30, "maximum": 900, "default": 240},
            "fallback_models": {"type": "array", "maxItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
          }
        }
      ]
    },
    "optionalAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "name", "model", "instructions"],
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string", "minLength": 1},
        "model": {"type": "string"},
        "instructions": {"type": "string"},
        "max_completion_tokens": {"type": "integer", "minimum": 64, "maximum": 16384},
        "timeout_seconds": {"type": "integer", "minimum": 30, "maximum": 900, "default": 240},
        "fallback_models": {"type": "array", "maxItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "allOf": [
        {
          "if": {"properties": {"enabled": {"const": true}}, "required": ["enabled"]},
          "then": {
            "properties": {
              "model": {"minLength": 1},
              "instructions": {"minLength": 1}
            }
          }
        }
      ]
    }
  }
}
