{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a15280020511/test2/execution_plan.schema.json",
  "title": "Web GPT Dynamic Expert Team Execution Plan",
  "description": "Web GPT 是任务规划者。必须先读取 OpenRouter 当前模型情报，再依据 selection_policy 针对具体任务动态选择专家、模型和组合方式。若对仓库使用、填表或编排不确定，可调用 DeepSeek Steward ASSIST；若发现任何仓库技术故障，应停止自行修码并交给 DeepSeek Steward REPAIR。",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "selection_policy", "task", "rationale", "experts", "stages", "red_team", "judge"],
  "properties": {
    "version": {"const": "1"},
    "selection_policy": {
      "type": "string",
      "const": "默认采用质量约束下的动态最优组合：先保证任务所需质量，再在满足质量的候选模型中优化成本和速度；随着任务复杂度、风险、价值和不确定性提高，自动增加专家数量、模型多样性和红队强度；重大任务以能力优先，普通任务以性价比优先。不得固定专家数量、固定模型或固定工作流，必须具体问题具体分析。",
      "description": "Web GPT 每次规划和填写 Execution Plan 时必须遵守的固定底层规则。"
    },
    "task": {"type": "string", "minLength": 1},
    "rationale": {
      "type": "string",
      "description": "说明本次如何依据 selection_policy，结合任务难度、价值、风险、不确定性以及 OpenRouter 当前模型能力、价格、延迟和上下文等信号，决定专家数量、模型与工作流组合。DeepSeek Steward ASSIST 可提供仓库和填表建议，但最终 Execution Plan 仍由 Web GPT 决定。"
    },
    "experts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "mission", "instructions", "model"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "mission": {"type": "string", "minLength": 1},
          "instructions": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1}
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mode", "members", "input_from"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "mode": {"enum": ["parallel", "sequential"]},
          "members": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "input_from": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "red_team": {"$ref": "#/$defs/optionalAgent"},
    "judge": {"$ref": "#/$defs/optionalAgent"}
  },
  "$defs": {
    "optionalAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "name", "model", "instructions"],
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string", "minLength": 1},
        "model": {"type": "string"},
        "instructions": {"type": "string"}
      },
      "allOf": [
        {
          "if": {"properties": {"enabled": {"const": true}}, "required": ["enabled"]},
          "then": {
            "properties": {
              "model": {"minLength": 1},
              "instructions": {"minLength": 1}
            }
          }
        }
      ]
    }
  }
}
